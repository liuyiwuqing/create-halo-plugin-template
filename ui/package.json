{
  "type": "module",
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "dev": "vite build --watch --mode=development",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path ../.gitignore --ignore-pattern build",
    "lint:eslint": "eslint . --fix --ignore-pattern build",
    "lint": "run-s lint:*",
    "prettier": "prettier --write src/",
    "test:unit": "vitest --passWithNoTests",
    "type-check": "vue-tsc --build",
    "verify": "run-s lint test:unit type-check"
  },
  "prettier": {
    "printWidth": 100,
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2
  },
  "dependencies": {
    "@halo-dev/api-client": "^2.23.0",
    "@halo-dev/components": "^2.23.0",
    "@halo-dev/ui-shared": "^2.23.0",
    "@tanstack/vue-table": "^8.21.3",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.468.0",
    "pinia": "^3.0.3",
    "radix-vue": "^1.9.12",
    "reka-ui": "^2.9.7",
    "tailwind-merge": "^2.6.0",
    "tw-animate-css": "^1.2.9",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.28",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4",
    "vue-sonner": "^1.3.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@halo-dev/ui-plugin-bundler-kit": "^2.23.0",
    "@iconify-json/ri": "^1.2.6",
    "@tailwindcss/vite": "^4.1.17",
    "@tsconfig/node20": "^20.1.6",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.19.1",
    "@vitest/eslint-plugin": "^1.2.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.29.0",
    "eslint-plugin-oxlint": "^0.16.12",
    "eslint-plugin-vue": "~10.0.1",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^7.0.2",
    "oxlint": "^0.16.12",
    "prettier": "^3.6.0",
    "sass": "^1.89.2",
    "shadcn-vue": "^2.6.2",
    "tailwindcss": "^4.1.17",
    "typescript": "~5.8.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.4"
  },
  "packageManager": "pnpm@10.12.4"
}
