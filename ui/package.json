{
  "type": "module",
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "dev": "vite build --watch --mode=development",
    "lint:oxlint": "oxlint . --fix -D correctness --ignore-path ../.gitignore --ignore-pattern build",
    "lint:eslint": "eslint . --fix --ignore-pattern build",
    "lint": "run-s lint:*",
    "prettier": "prettier --write src/",
    "test:unit": "vitest --passWithNoTests",
    "type-check": "vue-tsc --build",
    "verify": "run-s lint test:unit type-check"
  },
  "prettier": {
    "printWidth": 100,
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2
  },
  "dependencies": {
    "@halo-dev/api-client": "^2.24.0",
    "@halo-dev/components": "^2.24.0",
    "@halo-dev/ui-shared": "^2.24.0",
    "axios": "^1.16.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@halo-dev/ui-plugin-bundler-kit": "^2.24.0",
    "@iconify-json/ri": "^1.2.6",
    "@tailwindcss/vite": "^4.3.0",
    "@tsconfig/node20": "^20.1.6",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.2",
    "@vitest/eslint-plugin": "^1.6.17",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.1",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.3.0",
    "eslint-plugin-oxlint": "^1.63.0",
    "eslint-plugin-vue": "~10.9.1",
    "jsdom": "^29.1.1",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.63.0",
    "prettier": "^3.8.3",
    "sass": "^1.89.2",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.11",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.8"
  },
  "packageManager": "pnpm@10.12.4"
}
